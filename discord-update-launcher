#!/bin/bash
# Discord Auto-Update Launcher
# Checks for Discord updates before launching, installs if available.

DISCORD_BIN="/usr/share/discord/Discord"
DOWNLOAD_URL="https://discord.com/api/download?platform=linux&format=deb"
TMP_DEB="/tmp/discord-update.deb"
LOG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/discord-updater"
LOG_FILE="$LOG_DIR/update.log"
LOCK_FILE="/tmp/discord-updater.lock"
NOTIFY_ICON="discord"

# Ensure log directory exists
mkdir -p "$LOG_DIR"

# Log to both stdout and file
log() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    echo "$msg"
    echo "$msg" >> "$LOG_FILE"
}

# Send desktop notification
notify() {
    local urgency="${2:-normal}"
    notify-send -i "$NOTIFY_ICON" -a "Discord Updater" -u "$urgency" "Discord Updater" "$1" 2>/dev/null || true
}

# Rotate log if it gets too large (>100KB)
if [ -f "$LOG_FILE" ] && [ "$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)" -gt 102400 ]; then
    tail -n 200 "$LOG_FILE" > "$LOG_FILE.tmp" && mv "$LOG_FILE.tmp" "$LOG_FILE"
fi

# Get installed version
get_installed_version() {
    dpkg -s discord 2>/dev/null | grep '^Version:' | awk '{print $2}'
}

# Get latest version by following the redirect
get_latest_version() {
    local final_url
    final_url=$(curl -s -o /dev/null -w '%{url_effective}' -L \
        --connect-timeout 5 --max-time 10 "$DOWNLOAD_URL" 2>/dev/null)
    echo "$final_url" | grep -oP 'discord-\K[0-9]+\.[0-9]+\.[0-9]+'
}

# Compare versions: returns 0 if $1 < $2
version_lt() {
    [ "$(printf '%s\n' "$1" "$2" | sort -V | head -n1)" = "$1" ] && [ "$1" != "$2" ]
}

# Main update check
update_discord() {
    local installed latest
    installed=$(get_installed_version)

    if [ -z "$installed" ]; then
        log "[Discord Updater] Discord is not installed via dpkg. Skipping update check."
        return
    fi

    log "[Discord Updater] Installed version: $installed"
    log "[Discord Updater] Checking for updates..."
    notify "Checking for updates..."

    latest=$(get_latest_version)

    if [ -z "$latest" ]; then
        log "[Discord Updater] Could not determine latest version. Skipping update."
        notify "Could not check for updates. Launching anyway." "low"
        return
    fi

    log "[Discord Updater] Latest version: $latest"

    if version_lt "$installed" "$latest"; then
        log "[Discord Updater] Update available! Downloading $latest..."
        notify "⬇️ Downloading Discord $latest..." "normal"

        # Clean up any leftover temp file
        rm -f "$TMP_DEB"

        if curl -L -o "$TMP_DEB" --connect-timeout 10 --max-time 300 "$DOWNLOAD_URL" 2>/dev/null; then
            # Validate the downloaded file is a valid .deb package
            if dpkg-deb --info "$TMP_DEB" &>/dev/null; then
                log "[Discord Updater] Installing update..."
                notify "📦 Installing Discord $latest..."
                if sudo /usr/bin/apt install -y "$TMP_DEB" 2>&1 | tee -a "$LOG_FILE"; then
                    log "[Discord Updater] Successfully updated to $latest!"
                    notify "✅ Discord updated to $latest!" "normal"
                else
                    log "[Discord Updater] Installation failed. Launching existing version."
                    notify "⚠️ Update failed. Launching current version." "critical"
                fi
            else
                log "[Discord Updater] Downloaded file is not a valid .deb package. Skipping install."
                notify "⚠️ Downloaded file invalid. Launching current version." "critical"
            fi
            rm -f "$TMP_DEB"
        else
            log "[Discord Updater] Download failed. Launching existing version."
            notify "⚠️ Download failed. Launching current version." "critical"
            rm -f "$TMP_DEB"
        fi
    else
        log "[Discord Updater] Already up to date."
        notify "✅ Discord is up to date ($installed)"
    fi
}

# Use flock to prevent concurrent update attempts
(
    if flock -n 200; then
        update_discord
    else
        log "[Discord Updater] Another update is already in progress. Skipping."
    fi
) 200>"$LOCK_FILE"

# Launch Discord with any passed arguments
exec "$DISCORD_BIN" "$@"
